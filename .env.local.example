# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# ── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# In production, set this to: https://your-app-name.vercel.app

# ── Cron Security ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
CRON_SECRET=your_random_secret_here_change_this

# ── Optional: Manual sync trigger from dashboard ──────────────────────────────
NEXT_PUBLIC_SYNC_TRIGGER=your_random_secret_here_change_this
